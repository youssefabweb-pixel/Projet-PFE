## Diagramme de classes (PlantUML)

```plantuml
@startuml
title Modèle métier — gestion de projets bancaires

enum RoleUtilisateur {
  MANAGER
  MOA
  METIER
  DEVELOPPEMENT
}

enum StatutProjet {
  BROUILLON
  EN_COURS
  EN_RECETTE
  TERMINE
}

enum StatutEtape {
  EN_ATTENTE
  EN_COURS
  A_VALIDER
  VALIDEE
  REFUSEE
}

class Utilisateur {
  +id : Long
  +nomUtilisateur : String
  +email : String
  +role : RoleUtilisateur
  +actif : Boolean
}

class Projet {
  +id : Long
  +code : String
  +titre : String
  +statut : StatutProjet
}

class Etape {
  +id : Long
  +nom : String
  +ordre : Integer
  +statut : StatutEtape
}

class Validation {
  +id : Long
  +dateValidation : DateTime
  +approuve : Boolean
  +commentaire : String
}

class Document {
  +id : Long
  +titre : String
  +typeDocument : String
  +cheminStockage : String
  +version : Integer
}

class Tache {
  +id : Long
  +libelle : String
  +complete : Boolean
}

Utilisateur "1" -- "*" Projet : contribue
Projet "1" *-- "*" Etape
Etape "1" -- "*" Validation
Utilisateur "1" -- "*" Validation : valideur
Projet "1" o-- "*" Document
Etape "0..1" o-- "*" Document
Tache "*" -- "1" Etape
@enduml
```

